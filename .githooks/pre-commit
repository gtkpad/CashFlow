#!/bin/bash
set -eu

# Pre-commit hook: format + lint para projetos .NET

SOLUTION="CashFlow.sln"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' || true)

if [ -z "$STAGED_CS_FILES" ]; then
    echo -e "${GREEN}[pre-commit]${NC} Nenhum arquivo .cs no staging. Pulando verificacoes."
    exit 0
fi

STAGED_COUNT=$(echo "$STAGED_CS_FILES" | wc -l | tr -d ' ')
echo -e "${YELLOW}[pre-commit]${NC} Verificando ${STAGED_COUNT} arquivo(s) .cs..."

# 1. FORMAT
echo -e "${YELLOW}[pre-commit]${NC} Executando dotnet format..."

INCLUDE_ARGS=""
while IFS= read -r file; do
    INCLUDE_ARGS="$INCLUDE_ARGS --include $file"
done <<< "$STAGED_CS_FILES"

if ! dotnet format "$SOLUTION" --no-restore $INCLUDE_ARGS 2>&1; then
    echo -e "${RED}[pre-commit]${NC} dotnet format falhou."
    exit 1
fi

# Re-adiciona arquivos formatados ao staging
REFORMATTED_FILES=$(git diff --name-only -- '*.cs' || true)
if [ -n "$REFORMATTED_FILES" ]; then
    REFORMATTED_STAGED=$(comm -12 \
        <(echo "$STAGED_CS_FILES" | sort) \
        <(echo "$REFORMATTED_FILES" | sort) || true)

    if [ -n "$REFORMATTED_STAGED" ]; then
        echo "$REFORMATTED_STAGED" | xargs git add
        FIXED_COUNT=$(echo "$REFORMATTED_STAGED" | wc -l | tr -d ' ')
        echo -e "${GREEN}[pre-commit]${NC} ${FIXED_COUNT} arquivo(s) formatado(s) automaticamente."
    fi
fi

# 2. LINT (build)
echo -e "${YELLOW}[pre-commit]${NC} Executando dotnet build (lint)..."

if ! dotnet build "$SOLUTION" --no-restore --nologo -v quiet 2>&1 | tail -5; then
    echo ""
    echo -e "${RED}[pre-commit]${NC} Build falhou. Corrija os erros de lint antes de commitar."
    echo -e "${RED}[pre-commit]${NC} Dica: verifique os warnings tratados como erros (TreatWarningsAsErrors=true)."
    exit 1
fi

echo -e "${GREEN}[pre-commit]${NC} Todas as verificacoes passaram!"
