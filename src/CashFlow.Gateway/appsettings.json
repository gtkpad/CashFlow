{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "transactions-route": {
        "ClusterId": "transactions",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}"
        }
      },
      "consolidation-route": {
        "ClusterId": "consolidation",
        "Match": {
          "Path": "/api/v1/consolidation/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity/primary": {
            "Address": "https+http://identity"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:02:00"
          }
        }
      },
      "transactions": {
        "Destinations": {
          "transactions/primary": {
            "Address": "https+http://transactions"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:02:00"
          }
        }
      },
      "consolidation": {
        "Destinations": {
          "consolidation/primary": {
            "Address": "https+http://consolidation"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:02:00"
          }
        }
      }
    }
  }
}
